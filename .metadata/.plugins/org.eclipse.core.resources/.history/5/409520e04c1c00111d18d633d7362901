package com.ex;

public class Sudoku {
	
	public static boolean isSafe(int[][] sudoku,int row,int col,int digit) {
		// row
		for(int i=row; i<= 9 ;i++) {
			if(sudoku[i][col] == digit) {
				return false;
			}
		}
		
		// col
		for(int j=col; j<= 9 ; j++) {
			if(sudoku[row][j] == digit) {
				return false;
			}
		}
		
		// grid
		int sr = (row*3/3);
		int sc = (col*3/3);
		for(int i=sr ; i<=sr+3 ; i++) {
			for(int j=sc; j<=sc+3 ; j++) {
				if(sudoku[i][j] == digit) {
					return false;
				}
			}
		}
		return true;
	}
	public static boolean sudokuSolver(int[][] sudoku,int row,int col) {
		// base
		if(row == 9) {
			return false;
		}
		
		int nextRow = row, nextCol=col+1;
		if(col+1 == 9) {
			nextRow = row+1;
			nextCol = 0;
		}
		
		// if number already exit move to next
		if(sudoku[row][col] != 0) {
		 return	sudokuSolver(sudoku, nextRow, nextCol);
		}
		
		// if number not exits then place num
		for(int digits = 1 ; digits <= 9 ; digits++) {
			if (isSafe(sudoku,row,col,digits)) {
				sudoku[row][col] = digits;
				if(sudokuSolver(sudoku,nextRow,nextCol)){  // soln exists
						return true;
				}
				sudoku[row][col] = 0;  // if no soln then 0
			}	
		}
		return false;
	}
	
	public static void main(String[] args) {
		int[][] sudoku = {
				{0, 0, 8, 0, 0, 0, 0, 0, 0},
				{4, 9, 0, 1, 5, 7, 0, 0, 2},
				{0, 0, 3, 0, 0, 4, 1, 9, 0},
				{1, 8, 5, 0, 6, 0, 0, 2, 0},
				{0, 0, 0, 0, 2, 0, 0, 6, 0},
				{9, 6, 0, 4, 0, 5, 3, 0, 0},
				{0, 3, 0, 0, 7, 2, 0, 0, 4},
				{0, 4, 9, 0, 3, 0, 0, 5, 7},
				{8, 2, 7, 0, 0, 9, 0, 1, 3}};	
		sudokuSolver(sudoku,0,0);
	}
}